{
  "$schema": "https://unpkg.com/wrangler@latest/config-schema.json",
  "name": "blogeusz",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page",
  },
  "compatibility_date": "2026-03-20",

  "r2_buckets": [
    {
      "binding": "IMAGES_BUCKET",
      "bucket_name": "blogeusz-images",
    },
  ],
}

---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ImageCarousel from '../../components/ImageCarousel.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import BookmarkToggle from '../../components/BookmarkToggle.astro';
import ReadingProgress from '../../components/ReadingProgress.astro';
import PopularPosts from '../../components/PopularPosts.astro';
import { getReadingTime, formatDate } from '../../lib/utils';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const readingTime = getReadingTime(post.body || '');

const allPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

const idx = allPosts.findIndex((p) => p.id === post.id);
const prev = allPosts[idx + 1];
const next = allPosts[idx - 1];
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.coverImage}
  type="article"
  publishedAt={post.data.publishedAt}
>
  <ReadingProgress />

  <div class="post-wrapper">
    <aside class="sidebar-left">
      <div class="sidebar-actions">
        <a href="/blog" class="back-link" aria-label="Wróć do bloga">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path>
          </svg>
        </a>
        <BookmarkToggle slug={post.id} collection="blog" />
        <button
          class="share-btn"
          onclick="navigator.share?.({ title: document.title, url: window.location.href }) ?? navigator.clipboard.writeText(window.location.href)"
          aria-label="Udostępnij"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle
              cx="18"
              cy="19"
              r="3"></circle>
            <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line
              x1="15.41"
              y1="6.51"
              x2="8.59"
              y2="10.49"></line>
          </svg>
        </button>
      </div>
    </aside>

    <article class="post-content">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/blog">Dev</a>
        <span>/</span>
        <span>{post.data.title}</span>
      </nav>

      <header class="post-header">
        <div class="post-meta-top">
          <a href="/blog" class="back-link-mobile" aria-label="Wróć">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path>
            </svg>
          </a>
          <h1 class="post-title">{post.data.title}</h1>
        </div>
        <p class="post-meta">
          <span>Opublikowano {formatDate(post.data.publishedAt)}</span>
          <span>·</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="13"
            height="13"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <rect x="3" y="3" width="18" height="18" rx="2"></rect><path d="M3 9h18M9 21V9"></path>
          </svg>
          <span>{readingTime}m czytania</span>
        </p>
      </header>

      {
        post.data.images && post.data.images.length > 0 && (
          <ImageCarousel images={post.data.images} title={post.data.title} />
        )
      }

      <div class="prose-wrapper">
        <div class="prose">
          <Content />
        </div>

        <nav class="post-nav" aria-label="Artykuły">
          {
            prev && (
              <a href={`/blog/${prev.id}`} class="nav-post nav-post-prev">
                <span class="nav-label">← Poprzedni</span>
                <span class="nav-title">{prev.data.title}</span>
              </a>
            )
          }
          {
            next && (
              <a href={`/blog/${next.id}`} class="nav-post nav-post-next">
                <span class="nav-label">Następny →</span>
                <span class="nav-title">{next.data.title}</span>
              </a>
            )
          }
        </nav>

        <PopularPosts currentSlug={post.id} />
      </div>
    </article>

    <aside class="sidebar-right">
      <TableOfContents headings={headings} />
    </aside>
  </div>
</BaseLayout>

<style>
  .post-wrapper {
    max-width: calc(var(--max-width) + 300px);
    margin: 0 auto;
    padding: 2rem 2rem 4rem;
    display: grid;
    grid-template-columns: 56px 1fr 220px;
    gap: 2.5rem;
    align-items: start;
  }

  .sidebar-left {
    position: sticky;
    top: 80px;
  }

  .sidebar-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .back-link,
  .share-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-tag);
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
    color: var(--color-text-muted);
    cursor: pointer;
    text-decoration: none;
    transition:
      color 0.15s,
      border-color 0.15s;
  }

  .back-link:hover,
  .share-btn:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--color-accent);
  }

  .post-meta-top {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .back-link-mobile {
    display: none;
    margin-top: 0.375rem;
    flex-shrink: 0;
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .post-title {
    margin: 0 0 0.5rem;
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-text);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin: 0 0 1.5rem;
  }

  .prose-wrapper {
    margin-top: 2rem;
  }

  .prose :global(h2),
  .prose :global(h3) {
    color: var(--color-text);
    scroll-margin-top: 80px;
  }

  .prose :global(code) {
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    padding: 0.1em 0.3em;
    border-radius: 3px;
    font-size: 0.875em;
  }

  .prose :global(pre) {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
  }

  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
  }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .post-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .nav-post {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    text-decoration: none;
    color: inherit;
    max-width: 45%;
    transition: border-color 0.2s;
  }

  .nav-post:hover {
    border-color: var(--color-accent);
  }
  .nav-post-next {
    text-align: right;
    margin-left: auto;
  }

  .nav-label {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .nav-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.4;
  }

  @media (max-width: 1100px) {
    .post-wrapper {
      grid-template-columns: 1fr;
      max-width: var(--max-width);
    }
    .sidebar-left {
      display: none;
    }
    .sidebar-right {
      display: none;
    }
    .back-link-mobile {
      display: flex;
    }
  }

  @media (max-width: 640px) {
    .post-wrapper {
      padding: 1.5rem 1rem 3rem;
    }
    .post-title {
      font-size: 1.375rem;
    }
    .post-nav {
      flex-direction: column;
    }
    .nav-post {
      max-width: 100%;
    }
    .nav-post-next {
      text-align: left;
      margin-left: 0;
    }
  }
</style>

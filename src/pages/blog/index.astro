---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryTabs from '../../components/CategoryTabs.astro';
import TagFilter from '../../components/TagFilter.astro';
import PostCard from '../../components/PostCard.astro';
import { collectTags, getReadingTime } from '../../lib/utils';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const tags = collectTags(allPosts);
---

<BaseLayout title="Dev Blog">
  <section class="hero">
    <div class="hero-inner">
      <p class="hero-description">
        Blog o programowaniu i fotografii. Znajdziesz tu dużo wiedzy o różnych frameworkach jak i
        piękne zdjęcia.
      </p>
      <CategoryTabs active="dev" />
    </div>
  </section>

  <div class="content-wrapper">
    <TagFilter tags={tags} baseUrl="/tags" />

    <div class="grid-featured">
      {
        posts
          .filter((p) => p.data.featured)
          .slice(0, 2)
          .map((post) => (
            <PostCard
              slug={post.id}
              title={post.data.title}
              description={post.data.description}
              publishedAt={post.data.publishedAt}
              tags={post.data.tags}
              readingTime={getReadingTime(post.body || '')}
              coverImage={post.data.coverImage}
              size="large"
            />
          ))
      }
    </div>

    <div class="grid-posts">
      {
        posts
          .filter((p) => !p.data.featured)
          .map((post) => (
            <PostCard
              slug={post.id}
              title={post.data.title}
              description={post.data.description}
              publishedAt={post.data.publishedAt}
              tags={post.data.tags}
              readingTime={getReadingTime(post.body || '')}
              coverImage={post.data.coverImage}
            />
          ))
      }
    </div>
  </div>
</BaseLayout>

<style>
  .hero {
    border-bottom: 1px solid var(--color-border);
    padding: 3rem 0 2.5rem;
  }

  .hero-inner,
  .content-wrapper {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero-description {
    margin: 0 0 1.5rem;
    font-size: 1.25rem;
    color: var(--color-text);
    max-width: 52ch;
    line-height: 1.6;
  }

  .content-wrapper {
    padding-bottom: 4rem;
  }

  .grid-featured {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .grid-posts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 900px) {
    .grid-posts {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 640px) {
    .grid-featured,
    .grid-posts {
      grid-template-columns: 1fr;
    }
    .hero-inner,
    .content-wrapper {
      padding-left: 1rem;
      padding-right: 1rem;
    }
  }
</style>

---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate } from '../../lib/utils';

export async function getStaticPaths() {
  const items = await getCollection('til', ({ data }) => !data.draft && data.type === 'note');
  return items.map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await render(item);
---

<BaseLayout title={item.data.title}>
  <div class="wrapper">
    <a href="/til" class="back">← Wróć do TIL</a>

    <header class="til-header">
      <span class:list={['type-badge', item.data.type === 'note' ? 'type-note' : 'type-link']}>
        {item.data.type === 'note' ? 'TIL' : 'LINK'}
      </span>
      <h1 class="til-title">{item.data.title}</h1>
      <time class="til-date">{formatDate(item.data.publishedAt)}</time>
    </header>

    {
      item.data.url && (
        <a href={item.data.url} class="til-url" target="_blank" rel="noopener noreferrer">
          {item.data.url}
        </a>
      )
    }

    <div class="prose">
      <Content />
    </div>

    <div class="til-tags">
      {
        item.data.tags.map((tag) => (
          <a href={`/tags/${tag.toLowerCase()}`} class="tag">
            {tag}
          </a>
        ))
      }
    </div>
  </div>
</BaseLayout>

<style>
  .wrapper {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 2rem 4rem;
  }

  .back {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: color 0.15s;
  }

  .back:hover {
    color: var(--color-accent);
  }

  .til-header {
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .type-badge {
    display: inline-flex;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
    width: fit-content;
  }

  .type-note {
    background-color: rgba(232, 160, 32, 0.15);
    color: var(--color-accent);
  }
  .type-link {
    background-color: rgba(99, 179, 237, 0.15);
    color: #63b3ed;
  }

  .til-title {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-text);
  }

  .til-date {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .til-url {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--color-accent);
    text-decoration: none;
    margin-bottom: 1.5rem;
    word-break: break-all;
  }

  .til-url:hover {
    text-decoration: underline;
  }

  .prose {
    margin-bottom: 2rem;
  }

  .til-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.8125rem;
    padding: 0.25rem 0.625rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-tag);
    color: var(--color-text-muted);
    text-decoration: none;
    transition:
      color 0.15s,
      border-color 0.15s;
  }

  .tag:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
</style>

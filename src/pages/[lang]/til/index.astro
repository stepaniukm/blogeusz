---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CategoryTabs from '../../../components/CategoryTabs.astro';
import TilCard from '../../../components/TilCard.astro';
import TagFilter from '../../../components/TagFilter.astro';
import { collectTags } from '../../../lib/utils';
import { useTranslations } from '../../../i18n/utils';
import { locales } from '../../../i18n/ui';

export async function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as 'pl' | 'en');

const allTil = await getCollection(
  'til',
  ({ data }) => !data.draft && data.public && data.lang === lang
);
const items = allTil.toSorted(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
const tags = collectTags(allTil);
---

<BaseLayout title={t('til.title')} description={t('til.description')}>
  <section class="hero">
    <div class="inner">
      <p class="hero-description">
        {t('til.hero')}
      </p>
      <CategoryTabs active="til" />
    </div>
  </section>

  <div class="inner content">
    <TagFilter tags={tags} />

    {
      items.length > 0 ? (
        <div class="til-grid">
          {items.map((item) => (
            <TilCard
              slug={item.id}
              title={item.data.title}
              publishedAt={item.data.publishedAt}
              type={item.data.type}
              url={item.data.url}
              annotation={item.data.annotation}
              tags={item.data.tags}
            />
          ))}
        </div>
      ) : (
        <div class="empty-state" role="status" aria-live="polite">
          <h2 class="empty-title">{t('til.empty.title')}</h2>
          <p class="empty-description">{t('til.empty.description')}</p>
        </div>
      )
    }
  </div>
</BaseLayout>

<style>
  .hero {
    border-bottom: 1px solid var(--color-border);
    padding: 3rem 0 2.5rem;
  }

  .inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero-description {
    margin: 0 0 1.5rem;
    font-size: 1.25rem;
    color: var(--color-text);
    max-width: 52ch;
    line-height: 1.6;
  }

  .content {
    padding-bottom: 4rem;
  }

  .til-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .empty-state {
    margin-top: 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    background-color: var(--color-bg-card);
    padding: 2rem 1.25rem;
    text-align: center;
  }

  .empty-title {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .empty-description {
    margin: 0.5rem 0 0;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .til-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 640px) {
    .til-grid {
      grid-template-columns: 1fr;
    }
    .inner {
      padding: 0 1rem;
    }
  }
</style>

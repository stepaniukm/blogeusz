---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookmarksList from '../components/BookmarksList.vue';
---

<BaseLayout title="Zakładki" description="Twoje zapisane artykuły i notatki.">
  <div class="wrapper">
    <h1 class="page-title">Zakładki</h1>
    <p class="subtitle">Artykuły i notatki, które zapisałeś.</p>
    <BookmarksList client:only="vue" />
  </div>
</BaseLayout>

<style>
  .wrapper {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 2rem 4rem;
  }

  .page-title {
    margin: 0 0 0.5rem;
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .subtitle {
    margin: 0 0 2rem;
    color: var(--color-text-muted);
  }
</style>

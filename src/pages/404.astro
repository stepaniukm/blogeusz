---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';

const locale = getLangFromUrl(Astro.url);
const t = useTranslations(locale);
---

<BaseLayout title={t('404.title')}>
  <div class="wrapper">
    <span class="code">404</span>
    <h1 class="title">{t('404.heading')}</h1>
    <p class="desc">{t('404.message')}</p>
    <a href={getRelativeLocaleUrl(locale, '')} class="home-link">{t('404.back')}</a>
  </div>
</BaseLayout>

<style>
  .wrapper {
    max-width: 480px;
    margin: 6rem auto;
    padding: 0 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .code {
    font-size: 6rem;
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
  }

  .title {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .desc {
    margin: 0;
    color: var(--color-text-muted);
  }

  .home-link {
    margin-top: 0.5rem;
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
  }

  .home-link:hover {
    text-decoration: underline;
  }
</style>

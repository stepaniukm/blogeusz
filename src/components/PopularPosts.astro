---
import { getCollection } from 'astro:content';
import { getReadingTime } from '../lib/utils';

interface Props {
  currentSlug?: string;
  limit?: number;
}

const { currentSlug, limit = 4 } = Astro.props;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const popular = allPosts
  .filter(p => p.id !== currentSlug)
  .sort(() => Math.random() - 0.5) // TODO: replace with actual view count sorting
  .slice(0, limit);
---

{popular.length > 0 && (
  <section class="popular">
    <h2 class="popular-title">Popularne</h2>
    <div class="popular-grid">
      {popular.map(post => (
        <a href={`/blog/${post.id}`} class="popular-card">
          {post.data.coverImage && (
            <div class="popular-image">
              <img src={post.data.coverImage} alt={post.data.title} loading="lazy" decoding="async" />
            </div>
          )}
          <div class="popular-body">
            {post.data.tags[0] && (
              <span class="popular-tag">{post.data.tags[0].toUpperCase()}</span>
            )}
            <h3 class="popular-post-title">{post.data.title}</h3>
            <div class="popular-meta">
              <span>{getReadingTime(post.body || '')}m czytania</span>
              <span>·</span>
              <span>{post.data.publishedAt.toLocaleDateString('pl-PL', { day: '2-digit', month: '2-digit', year: 'numeric' })}</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .popular { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--color-border); }
  .popular-title { margin: 0 0 1.25rem; font-size: 1.125rem; font-weight: 700; color: var(--color-text); }

  .popular-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }

  .popular-card {
    display: flex;
    flex-direction: column;
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s;
  }

  .popular-card:hover { border-color: var(--color-accent); }

  .popular-image {
    aspect-ratio: 16/10;
    overflow: hidden;
  }

  .popular-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .popular-body {
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .popular-tag {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--color-accent);
  }

  .popular-post-title {
    margin: 0;
    font-size: 0.8125rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-text);
  }

  .popular-meta {
    display: flex;
    gap: 0.375rem;
    font-size: 0.6875rem;
    color: var(--color-text-muted);
  }
</style>

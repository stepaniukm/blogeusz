---
import ThemeToggle from './ThemeToggle.vue';
import LangSwitcher from './LangSwitcher.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';

const locale = getLangFromUrl(Astro.url);
const t = useTranslations(locale);

const navLinks = [
  { href: getRelativeLocaleUrl(locale, ''), label: t('nav.home') },
  { href: getRelativeLocaleUrl(locale, 'blog'), label: t('nav.blog') },
  { href: getRelativeLocaleUrl(locale, 'til'), label: t('nav.til') },
  { href: getRelativeLocaleUrl(locale, 'photos'), label: t('nav.photos') },
];

const currentPath = Astro.url.pathname;
---

<header class="header">
  <div class="header-inner">
    <a href={getRelativeLocaleUrl(locale, '')} class="logo-link" aria-label={t('logo.label')}>
      <img src="/logo.svg" alt="blogeusz" width="140" height="28" class="logo logo-dark" />
      <img src="/logo-light.svg" alt="blogeusz" width="140" height="28" class="logo logo-light" />
    </a>

    <nav class="nav" aria-label={t('nav.main.label')}>
      {
        navLinks.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              'nav-link',
              { active: currentPath === href || (href !== `/${locale}/` && currentPath.startsWith(href)) },
            ]}
          >
            {label}
          </a>
        ))
      }
    </nav>

    <div class="header-actions">
      <LangSwitcher />
      <a href={getRelativeLocaleUrl(locale, 'bookmarks')} class="icon-btn" aria-label={t('nav.bookmarks.label')}>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"></path>
        </svg>
      </a>
      <ThemeToggle label={t('theme.toggle')} client:load />
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg-nav);
    border-bottom: 1px solid var(--color-border);
    backdrop-filter: blur(8px);
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
    height: 60px;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .logo-link {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .nav {
    display: flex;
    gap: 0.25rem;
    margin-left: auto;
  }

  .nav-link {
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius-tag);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition:
      color 0.15s,
      background-color 0.15s;
  }

  .nav-link:hover {
    color: var(--color-text);
    background-color: var(--color-tag-bg);
  }

  .nav-link.active {
    color: var(--color-text);
    background-color: var(--color-tag-bg);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-tag);
    color: var(--color-text-muted);
    text-decoration: none;
    transition:
      color 0.15s,
      background-color 0.15s;
    cursor: pointer;
  }

  .icon-btn:hover {
    color: var(--color-text);
    background-color: var(--color-tag-bg);
  }

  @media (max-width: 640px) {
    .nav {
      display: none;
    }
    .header-inner {
      padding: 0 1rem;
    }
  }
</style>

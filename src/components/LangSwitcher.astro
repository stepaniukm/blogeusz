---
import { getLangFromUrl } from '../i18n/utils';
import { locales } from '../i18n/ui';

const current = getLangFromUrl(Astro.url);

function swapLocale(url: URL, targetLang: string): string {
  const [, , ...rest] = url.pathname.split('/');
  return `/${targetLang}/${rest.join('/')}`;
}
---

<div class="lang-switcher">
  {
    locales.map((lang) => (
      <a
        href={swapLocale(Astro.url, lang)}
        class:list={['lang-link', lang === current && 'active']}
        hreflang={lang}
        aria-current={lang === current ? 'true' : undefined}
      >
        {lang.toUpperCase()}
      </a>
    ))
  }
</div>

<style>
  .lang-switcher {
    display: flex;
    gap: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-tag);
    overflow: hidden;
    flex-shrink: 0;
  }

  .lang-link {
    padding: 0.25rem 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    text-decoration: none;
    background-color: transparent;
    border-right: 1px solid var(--color-border);
    transition:
      color 0.15s,
      background-color 0.15s;
  }

  .lang-link:last-child {
    border-right: none;
  }

  .lang-link:hover {
    color: var(--color-text);
    background-color: var(--color-tag-bg);
  }

  .lang-link.active {
    color: var(--color-accent);
    background-color: var(--color-tag-bg);
  }
</style>

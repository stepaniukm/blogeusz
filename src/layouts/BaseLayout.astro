---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedAt?: Date;
}

const {
  title,
  description = 'Blog o programowaniu i fotografii. Znajdziesz tu dużo wiedzy o różnych frameworkach jak i piękne zdjęcia.',
  image = '/og/default.png',
  type = 'website',
  publishedAt,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = image.startsWith('http') ? image : new URL(image, Astro.site).toString();
---

<!doctype html>
<html lang="pl" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="blogeusz" href="/rss.xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{title} | blogeusz</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | blogeusz`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    {publishedAt && <meta property="article:published_time" content={publishedAt.toISOString()} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | blogeusz`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <ClientRouter />

    <script is:inline>
      (function () {
        function applyTheme() {
          const theme = localStorage.getItem('theme') || 'dark';
          document.documentElement.setAttribute('data-theme', theme);
        }
        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>
  </head>
  <body>
    <div class="side-pattern side-pattern-left" aria-hidden="true"></div>
    <div class="side-pattern side-pattern-right" aria-hidden="true"></div>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
